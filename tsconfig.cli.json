{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "outDir": "./out/cli",
    "rootDir": "./src/cli",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src/cli/**/*.ts"]
}
